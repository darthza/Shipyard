@page "/"
@inject IDockerContainerService DockerContainers
@implements IDisposable

<PageTitle>Shipyard</PageTitle>

<section class="page-heading">
    <div>
        <p class="eyebrow">Docker Monitor</p>
        <h1>Containers</h1>
    </div>
    <div class="toolbar">
        <label class="auto-refresh">
            <input type="checkbox" @bind="autoRefresh" @bind:after="OnAutoRefreshChanged" />
            Auto-refresh
        </label>
        <button class="btn btn-outline-secondary" @onclick="LoadContainersAsync" disabled="@isBusy">Refresh</button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert alert-success" role="status">@statusMessage</div>
}

@if (containers is null)
{
    <p>Loading containers...</p>
}
else if (containers.Count == 0)
{
    <div class="empty-state">
        <h2>No containers found</h2>
        <p>Start a Docker container and refresh this page to inspect it.</p>
    </div>
}
else
{
    var groups = GetContainerGroups();
    var standaloneContainers = GetStandaloneContainers();

    <div class="table-wrap">
        <table class="table align-middle container-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Image</th>
                    <th>Status</th>
                    <th>Ports</th>
                    <th>Created</th>
                    <th class="actions-column">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var group in groups)
                {
                    <tr class="group-row">
                        <td>
                            <button class="group-toggle" @onclick="() => ToggleGroup(group.Name)" aria-expanded="@IsGroupExpanded(group.Name)">
                                <span class="group-chevron @(IsGroupExpanded(group.Name) ? "expanded" : null)">›</span>
                                <span>
                                    <span class="container-name">@group.Name</span>
                                    <span class="group-type">@group.Type</span>
                                </span>
                            </button>
                        </td>
                        <td>@($"{group.Containers.Count} containers")</td>
                        <td>
                            <span class="status-pill group-status @(group.RunningCount > 0 ? "running" : "stopped")">
                                @($"{group.RunningCount} running")
                            </span>
                            <div class="status-detail">@($"{group.StoppedCount} stopped")</div>
                        </td>
                        <td>@FormatGroupPorts(group)</td>
                        <td>@group.Created.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="muted">Group</td>
                    </tr>

                    @if (IsGroupExpanded(group.Name))
                    {
                        @foreach (var container in group.Containers)
                        {
                            <ContainerTableRow Container="container" RowClass="child-row" IsBusy="isBusy" OnStart="StartContainerAsync" OnStop="StopContainerAsync" />
                        }
                    }
                }

                @foreach (var container in standaloneContainers)
                {
                    <ContainerTableRow Container="container" IsBusy="isBusy" OnStart="StartContainerAsync" OnStop="StopContainerAsync" />
                }
            </tbody>
        </table>
    </div>
}

@code {
    private IReadOnlyList<ContainerSummary>? containers;
    private readonly HashSet<string> collapsedGroups = new(StringComparer.OrdinalIgnoreCase);
    private bool isBusy;
    private bool autoRefresh;
    private string? errorMessage;
    private string? statusMessage;
    private PeriodicTimer? refreshTimer;
    private CancellationTokenSource? refreshCancellation;

    protected override async Task OnInitializedAsync()
    {
        await LoadContainersAsync();
    }

    private async Task LoadContainersAsync()
    {
        await RunWithMessagesAsync(async () =>
        {
            containers = await DockerContainers.GetContainersAsync();
            SyncGroupExpansionState();
        });
    }

    private async Task StartContainerAsync(ContainerSummary container)
    {
        await RunWithMessagesAsync(async () =>
        {
            await DockerContainers.StartContainerAsync(container.Id);
            statusMessage = $"Started {container.Name}.";
            containers = await DockerContainers.GetContainersAsync();
        });
    }

    private async Task StopContainerAsync(ContainerSummary container)
    {
        await RunWithMessagesAsync(async () =>
        {
            await DockerContainers.StopContainerAsync(container.Id);
            statusMessage = $"Stopped {container.Name}.";
            containers = await DockerContainers.GetContainersAsync();
        });
    }

    private async Task RunWithMessagesAsync(Func<Task> action)
    {
        errorMessage = null;
        statusMessage = null;
        isBusy = true;

        try
        {
            await action();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private IReadOnlyList<ContainerGroup> GetContainerGroups()
    {
        if (containers is null)
        {
            return [];
        }

        return containers
            .Where(container => container.IsGrouped)
            .GroupBy(container => container.GroupName!, StringComparer.OrdinalIgnoreCase)
            .Select(group => new ContainerGroup(
                group.Key,
                group.First().GroupType ?? "Group",
                group.OrderBy(container => container.Name).ToList()))
            .OrderBy(group => group.Name)
            .ToList();
    }

    private IReadOnlyList<ContainerSummary> GetStandaloneContainers()
    {
        if (containers is null)
        {
            return [];
        }

        return containers
            .Where(container => !container.IsGrouped)
            .OrderByDescending(container => container.Created)
            .ToList();
    }

    private bool IsGroupExpanded(string groupName) => !collapsedGroups.Contains(groupName);

    private void ToggleGroup(string groupName)
    {
        if (!collapsedGroups.Add(groupName))
        {
            collapsedGroups.Remove(groupName);
        }
    }

    private void SyncGroupExpansionState()
    {
        var groupNames = GetContainerGroups().Select(group => group.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);
        collapsedGroups.RemoveWhere(groupName => !groupNames.Contains(groupName));
    }

    private static string FormatGroupPorts(ContainerGroup group)
    {
        var portCount = group.Containers.Sum(container => container.Ports.Count);
        return portCount == 0 ? "None" : $"{portCount} exposed";
    }

    private void OnAutoRefreshChanged()
    {
        refreshCancellation?.Cancel();
        refreshTimer?.Dispose();

        if (!autoRefresh)
        {
            return;
        }

        refreshCancellation = new CancellationTokenSource();
        refreshTimer = new PeriodicTimer(TimeSpan.FromSeconds(5));
        _ = AutoRefreshAsync(refreshCancellation.Token);
    }

    private async Task AutoRefreshAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (refreshTimer is not null && await refreshTimer.WaitForNextTickAsync(cancellationToken))
            {
                containers = await DockerContainers.GetContainersAsync(cancellationToken);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    public void Dispose()
    {
        refreshCancellation?.Cancel();
        refreshCancellation?.Dispose();
        refreshTimer?.Dispose();
    }
}
